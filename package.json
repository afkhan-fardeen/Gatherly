{
  "name": "gatherly",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev -w api",
    "dev:consumer": "npm run dev -w consumer",
    "dev:vendor": "npm run dev -w vendor",
    "dev:admin": "npm run dev -w admin",
    "build": "npm run build -w @gatherly/shared && npm run build -w api && npm run build -w consumer && npm run build -w vendor && npm run build -w admin",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:studio": "npm run db:studio -w api",
    "db:migrate": "npm run db:migrate -w api",
    "db:migrate:deploy": "npm run db:migrate:deploy -w api",
    "db:migrate:neon": "npm run db:migrate:neon -w api",
    "db:migrate:all": "npm run db:migrate:all -w api",
    "db:seed": "npm run db:seed -w api",
    "test:api": "bash scripts/test-api.sh"
  },
  "engines": {
    "node": ">=18"
  }
}
